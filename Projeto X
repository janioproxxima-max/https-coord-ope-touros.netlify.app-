  const kpis = `
  <div class="kpi-strip" style="grid-template-columns:repeat(4,1fr)">
    <div class="kpi cyan"><div class="kpi-label">Total OS</div><div class="kpi-value">${ds.length}</div><div class="kpi-sub">${label}</div></div>
    <div class="kpi red"><div class="kpi-label">SLA vencido</div><div class="kpi-value">${v}</div><div class="kpi-sub">ação imediata</div></div>
    <div class="kpi yellow"><div class="kpi-label">Atender hoje</div><div class="kpi-value">${h}</div><div class="kpi-sub">risco de vencer</div></div>
    <div class="kpi green"><div class="kpi-label">Dentro do prazo</div><div class="kpi-value">${ok}</div><div class="kpi-sub">pode esperar</div></div>
  </div>`;

  const cityBlock = `
  <div class="two-col">
    <div class="card">
      <div class="card-head"><h3>📍 Pareto por cidade</h3></div>
      <div class="city-list">
        ${cities.map(([cidade, d]) => {
          const pct = Math.round(d.total/maxT*100);
          const barColor = d.vencido>0 ? 'red' : d.hoje>0 ? 'yellow' : 'green';
          return `<div class="city-row">
            <div class="city-meta">
              <span class="city-name">${cidade}</span>
              <div class="city-nums">
                <span class="city-total">${d.total} OS</span>
                ${d.vencido>0 ? `<span class="city-alert">${d.vencido} venc.</span>` : ''}
                ${d.hoje>0 ? `<span class="city-warn">${d.hoje} hoje</span>` : ''}
              </div>
            </div>
            <div class="bar-track"><div class="bar-fill ${barColor}" style="width:${pct}%"></div></div>
          </div>`;
        }).join('')}
      </div>
    </div>
    <div class="card">
      <div class="card-head"><h3>Status das OS</h3></div>
      <div class="status-list">
        ${[...new Set(ds.map(o=>o.status))].map(s => `<div class="status-row"><span class="status-name" style="font-size:.85em">${s}</span><span class="status-val" style="color:var(--brand)">${ds.filter(o=>o.status===s).length}</span></div>`).join('')}
      </div>
    </div>
  </div>`;

  const tabela = `
  <div class="tbl-wrap"><table>
    <thead><tr><th>Protocolo</th><th>Serviço</th><th>Cidade</th><th>Bairro</th><th>Tempo (h)</th><th>Status</th><th>SLA</th></tr></thead>
    <tbody>${[...ds].sort((a,b) => {
      const ord = { VENCIDO:0, 'ATENDER HOJE':1, 'PODE ESPERAR':2 };
      return (ord[a.sla]??3) - (ord[b.sla]??3);
    }).map(o => `<tr>
      <td class="proto">${o.prot}</td><td>${o.titulo}</td><td>${o.cidade}</td>
      <td style="color:var(--ink-dim);font-size:.85em">${o.bairro}</td>
      <td class="proto" style="color:${o.sla==='VENCIDO'?'var(--crit)':o.sla==='ATENDER HOJE'?'var(--warn)':'var(--ok)'};font-weight:700">${o.tempo}h</td>
      <td><span class="badge-status">${o.status}</span></td>
      <td><span class="badge-sla ${slaClass(o.sla)}">${slaLabel(o.sla)}</span></td>
    </tr>`).join('')}</tbody>
  </table></div>`;

  return kpis + cityBlock + tabela;
}

function buildParetoPage(){
  const cityMap = {};
  Object.values(DATASETS).flat().forEach(o => {
    if (!cityMap[o.cidade]) cityMap[o.cidade] = { total:0, v:0, h:0, ok:0, sla24:0, sla48:0, ativ:0, mde:0, erro:0 };
    const c = cityMap[o.cidade];
    c.total++;
    if (o.sla==='VENCIDO') c.v++; else if (o.sla==='ATENDER HOJE') c.h++; else c.ok++;
  });
  SLA24.forEach(o => { if (cityMap[o.cidade]) cityMap[o.cidade].sla24++; });
  SLA48.forEach(o => { if (cityMap[o.cidade]) cityMap[o.cidade].sla48++; });
  ATIVACAO.forEach(o => { if (cityMap[o.cidade]) cityMap[o.cidade].ativ++; });
  MDE.forEach(o => { if (cityMap[o.cidade]) cityMap[o.cidade].mde++; });
  ERRO_PROJ.forEach(o => { if (cityMap[o.cidade]) cityMap[o.cidade].erro++; });

  const cities = Object.entries(cityMap).sort((a,b) => b[1].total - a[1].total);
  return `
  <div class="sec-hdr">Pareto por cidade — todas as abas</div>
  <div class="tbl-wrap"><table>
    <thead><tr><th>Cidade</th><th>Total</th><th>Vencido</th><th>Hoje</th><th>OK</th><th>SLA 24h</th><th>SLA 48h</th><th>Ativação</th><th>MDE</th><th>Erro proj.</th></tr></thead>
    <tbody>${cities.map(([cidade,d]) => `<tr>
      <td style="font-weight:700">${cidade}</td>
      <td class="proto" style="color:var(--brand);font-weight:700">${d.total}</td>
      <td class="proto" style="color:${d.v>0?'var(--crit)':'var(--ink-dim)'};font-weight:700">${d.v||'—'}</td>
      <td class="proto" style="color:${d.h>0?'var(--warn)':'var(--ink-dim)'};font-weight:700">${d.h||'—'}</td>
      <td class="proto" style="color:var(--ok)">${d.ok}</td>
      <td style="color:var(--ink-dim)">${d.sla24||'—'}</td>
      <td style="color:var(--ink-dim)">${d.sla48||'—'}</td>
      <td style="color:var(--ink-dim)">${d.ativ||'—'}</td>
      <td style="color:var(--ink-dim)">${d.mde||'—'}</td>
      <td style="color:var(--ink-dim)">${d.erro||'—'}</td>
    </tr>`).join('')}</tbody>
  </table></div>`;
}

function buildAlertas(){
  const criticas = Object.entries(DATASETS).flatMap(([k,ds]) =>
    ds.filter(o => o.sla==='VENCIDO' || o.sla==='ATENDER HOJE').map(o => ({...o, tipo: DS_LABELS[k]}))
  ).sort((a,b) => b.tempo - a.tempo);
  const v = criticas.filter(o=>o.sla==='VENCIDO').length;
  const h = criticas.filter(o=>o.sla==='ATENDER HOJE').length;

  return `
  <div class="kpi-strip" style="grid-template-columns:repeat(3,1fr)">
    <div class="kpi red"><div class="kpi-label">SLA vencido</div><div class="kpi-value">${v}</div><div class="kpi-sub">ação imediata</div></div>
    <div class="kpi yellow"><div class="kpi-label">Atender hoje</div><div class="kpi-value">${h}</div><div class="kpi-sub">risco de vencer</div></div>
    <div class="kpi green"><div class="kpi-label">Total de alertas</div><div class="kpi-value">${criticas.length}</div><div class="kpi-sub">pendentes</div></div>
  </div>
  <div class="tbl-wrap">
    <div class="card-head"><h3>⚡ Todas as OS críticas</h3><span class="cnt-badge">${criticas.length}</span></div>
    <table>
      <thead><tr><th>Protocolo</th><th>Tipo SLA</th><th>Serviço</th><th>Cidade</th><th>Tempo (h)</th><th>Status</th><th>Prioridade</th></tr></thead>
      <tbody>${criticas.map(o => `<tr>
        <td class="proto">${o.prot}</td>
        <td style="font-size:.8em;color:var(--accent2)">${o.tipo}</td>
        <td>${o.titulo}</td><td>${o.cidade}</td>
        <td class="proto" style="color:${o.sla==='VENCIDO'?'var(--crit)':'var(--warn)'};font-weight:700">${o.tempo}h</td>
        <td><span class="badge-status">${o.status}</span></td>
        <td><span class="badge-sla ${slaClass(o.sla)}">${slaLabel(o.sla)}</span></td>
      </tr>`).join('')}</tbody>
    </table>
  </div>`;
}

let currentTab = 'visao';
function setTab(tab){
  currentTab = tab;
  document.querySelectorAll('.sla-tab').forEach(el => el.classList.toggle('active', el.dataset.tab === tab));
  const c = document.getElementById('indicadores-content');
  if (tab === 'visao') c.innerHTML = buildVisao();
  else if (tab === 'pareto') c.innerHTML = buildParetoPage();
  else if (tab === 'alertas') c.innerHTML = buildAlertas();
  else c.innerHTML = buildSLAPage(tab);
}

document.getElementById('sla-tabs').innerHTML = Object.keys(DS_LABELS).map(key => {
  let count = '';
  if (DATASETS[key]) count = `<span class="cnt-badge" style="margin-left:6px">${DATASETS[key].length}</span>`;
  return `<div class="sla-tab" data-tab="${key}" onclick="setTab('${key}')">${DS_LABELS[key]}${count}</div>`;
}).join('');

setTab('visao');
</script>
</body>
</html>

/* ===================================================================
   Coordenação de Operações · Touros — Design tokens
   Painel de operações de campo (fibra/telecom): denso em dados,
   feito para leitura rápida de status (prazo) e localização geográfica.
=================================================================== */

@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap');

:root{
  /* superfícies */
  --bg:            #0b0f1a;
  --bg-panel:      #121929;
  --bg-panel-2:    #1a2236;
  --bg-raised:     #1e2740;
  --line:          #1e2d47;
  --line-soft:     #16203a;

  /* texto */
  --ink:           #e2eaf5;
  --ink-dim:       #5e7a9e;
  --ink-faint:     #3d5470;

  /* marca / acento primário — ciano do painel de operações */
  --brand:         #00d4ff;
  --brand-dim:     #0099cc;
  --brand-wash:    rgba(0,212,255,0.12);

  /* sinalização de prazo */
  --ok:            #00e5a0;
  --ok-wash:       rgba(0,229,160,0.12);
  --warn:          #ffd166;
  --warn-wash:     rgba(255,209,102,0.12);
  --crit:          #ff4d6d;
  --crit-wash:     rgba(255,77,109,0.12);

  /* acento secundário (usado em destaques/indicadores) */
  --accent2:       #a78bfa;
  --accent2-wash:  rgba(167,139,250,0.12);
  --accent3:       #ff9a3c;

  /* tipografia */
  --f-display:     'JetBrains Mono', ui-monospace, monospace;
  --f-body:        'Inter', system-ui, sans-serif;

  --radius:        10px;
  --radius-sm:     6px;
  --shadow:        0 8px 24px rgba(0,0,0,0.35);
}

*{ box-sizing:border-box; }
html,body{ margin:0; padding:0; }
body{
  background:var(--bg);
  color:var(--ink);
  font-family:var(--f-body);
  font-size:15px;
  line-height:1.5;
  -webkit-font-smoothing:antialiased;
}
a{ color:inherit; }
button, input, select{ font-family:inherit; font-size:inherit; }
::selection{ background:var(--brand-wash); color:var(--ink); }

/* faint grid texture behind everything, evokes a coverage/coordinate grid */
.grid-field{
  position:fixed; inset:0; z-index:-1; pointer-events:none;
  background-image:
    linear-gradient(var(--line-soft) 1px, transparent 1px),
    linear-gradient(90deg, var(--line-soft) 1px, transparent 1px);
  background-size:40px 40px;
  -webkit-mask-image: radial-gradient(ellipse at 20% 0%, black 0%, transparent 70%);
          mask-image: radial-gradient(ellipse at 20% 0%, black 0%, transparent 70%);
  opacity:.5;
}

/* ---------------- app shell: sidebar + topbar ---------------- */
body.has-shell{ display:flex; height:100vh; overflow:hidden; }

.sidebar{
  width:210px; flex-shrink:0; background:var(--bg-panel);
  border-right:1px solid var(--line);
  display:flex; flex-direction:column; height:100vh; overflow-y:auto;
}
.sidebar .sb-brand{ padding:18px 16px 14px; border-bottom:1px solid var(--line); }
.sidebar .sb-brand .tag{
  font-size:10.5px; font-weight:700; letter-spacing:.14em; color:var(--brand);
  text-transform:uppercase; margin-bottom:3px;
}
.sidebar .sb-brand h1{ font-size:14.5px; font-weight:700; margin:0; }
.sidebar .sb-brand p{ font-size:11.5px; color:var(--ink-dim); margin:2px 0 0; }
.sidebar .sb-section{
  padding:14px 12px 4px; font-size:10.5px; color:var(--ink-faint);
  text-transform:uppercase; letter-spacing:.1em;
}
.sidebar a.sb-item{
  display:flex; align-items:center; gap:8px; padding:9px 12px; margin:1px 6px;
  border-radius:7px; cursor:pointer; font-size:13.5px; color:var(--ink-dim);
  text-decoration:none; user-select:none;
}
.sidebar a.sb-item:hover{ background:var(--bg-panel-2); color:var(--ink); }
.sidebar a.sb-item.active{ background:var(--brand-wash); color:var(--brand); font-weight:600; }
.sidebar .sb-item .ico{ font-size:14px; width:18px; text-align:center; }
.sidebar .sb-footer{ margin-top:auto; padding:12px; border-top:1px solid var(--line); }
.sidebar .sb-update{ font-size:10px; color:var(--ink-faint); text-transform:uppercase; letter-spacing:.06em; margin-bottom:2px; }
.sidebar .sb-date{ font-size:12.5px; color:var(--brand); font-family:var(--f-display); font-weight:600; }

.shell-main{ flex:1; display:flex; flex-direction:column; overflow:hidden; height:100vh; }

.topbar{
  height:52px; flex-shrink:0; background:var(--bg-panel);
  border-bottom:1px solid var(--line);
  display:flex; align-items:center; padding:0 22px; gap:10px;
}
.topbar .crumb{ display:flex; align-items:center; gap:8px; font-size:13px; }
.topbar .crumb .unit{ color:var(--ink-dim); }
.topbar .crumb .sep{ color:var(--ink-faint); }
.topbar .crumb .page{ font-weight:600; color:var(--brand); }
.topbar .spacer{ flex:1; }
.topbar .clock{ font-family:var(--f-display); font-size:12px; color:var(--ink-faint); }
.topbar .user-pill{
  background:var(--brand-wash); border:1px solid rgba(0,212,255,.25); border-radius:20px;
  padding:4px 11px; font-size:12.5px; color:var(--brand); cursor:pointer; border-width:1px;
}
.topbar .user-pill:hover{ background:var(--crit-wash); border-color:rgba(255,77,109,.3); color:var(--crit); }

.shell-content{ flex:1; overflow-y:auto; }

/* ---------------- layout shells ---------------- */
.page{ max-width:1360px; margin:0 auto; padding:28px 24px 64px; }
.page-head{ margin-bottom:22px; }
.eyebrow{
  font-family:var(--f-display); font-size:11.5px; letter-spacing:.14em;
  text-transform:uppercase; color:var(--brand); margin:0 0 6px;
}
h1.page-title{ font-size:26px; margin:0 0 4px; font-weight:800; letter-spacing:-.01em; }
.page-sub{ color:var(--ink-dim); font-size:14px; margin:0; }

.panel{
  background:var(--bg-panel);
  border:1px solid var(--line);
  border-radius:var(--radius);
}

/* ---------------- stat cards ---------------- */
.stat-row{
  display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:12px; margin-bottom:20px;
}
.stat-card{
  background:var(--bg-panel);
  border:1px solid var(--line);
  border-radius:var(--radius);
  padding:16px 18px;
  position:relative; overflow:hidden;
}
.stat-card .label{
  font-size:11.5px; color:var(--ink-faint); text-transform:uppercase;
  letter-spacing:.08em; font-weight:600; margin-bottom:8px;
}
.stat-card .value{
  font-family:var(--f-display); font-size:28px; font-weight:700; letter-spacing:-.01em;
}
.stat-card .value small{ font-size:14px; color:var(--ink-dim); font-weight:500; }
.stat-card.ok .value{ color:var(--ok); }
.stat-card.crit .value{ color:var(--crit); }
.stat-card.brand .value{ color:var(--brand); }

/* ---------------- toolbar / filters ---------------- */
.toolbar{
  display:flex; flex-wrap:wrap; gap:10px; align-items:center;
  padding:14px 16px; margin-bottom:16px;
}
.field{ display:flex; flex-direction:column; gap:4px; }
.field label{ font-size:11px; color:var(--ink-faint); font-weight:600; text-transform:uppercase; letter-spacing:.06em; }
select, .input{
  background:var(--bg-raised); color:var(--ink);
  border:1px solid var(--line); border-radius:var(--radius-sm);
  padding:8px 10px; min-width:150px;
}
select:focus, .input:focus, button:focus-visible{
  outline:2px solid var(--brand); outline-offset:1px;
}
.btn{
  display:inline-flex; align-items:center; gap:6px;
  background:var(--bg-raised); color:var(--ink);
  border:1px solid var(--line); border-radius:var(--radius-sm);
  padding:9px 14px; font-weight:600; font-size:13.5px;
  cursor:pointer; text-decoration:none;
}
.btn:hover{ border-color:var(--brand); color:var(--brand); }
.btn.primary{ background:var(--brand); border-color:var(--brand); color:#0B1512; }
.btn.primary:hover{ background:var(--brand-dim); color:#0B1512; }
.btn.ghost{ background:transparent; }
.btn.danger:hover{ border-color:var(--crit); color:var(--crit); }
.btn[disabled]{ opacity:.45; cursor:not-allowed; }

/* ---------------- view toggle (tabs) ---------------- */
.view-toggle{ display:flex; gap:2px; background:var(--bg-raised); border:1px solid var(--line); border-radius:var(--radius-sm); padding:3px; }
.view-toggle button{
  border:none; background:transparent; color:var(--ink-dim);
  padding:7px 14px; border-radius:5px; font-weight:600; font-size:13px; cursor:pointer;
}
.view-toggle button.active{ background:var(--brand); color:#0B1512; }

/* ---------------- split layout: table + map ---------------- */
.split{
  display:grid; grid-template-columns:1.15fr 1fr; gap:16px; align-items:start;
}
@media (max-width:980px){ .split{ grid-template-columns:1fr; } }

/* ---------------- table ---------------- */
.table-wrap{ overflow:auto; max-height:640px; }
table.services{ width:100%; border-collapse:collapse; font-size:13.3px; }
table.services thead th{
  position:sticky; top:0; background:var(--bg-panel-2);
  text-align:left; padding:10px 12px; font-size:11px; text-transform:uppercase;
  letter-spacing:.05em; color:var(--ink-faint); border-bottom:1px solid var(--line);
  cursor:pointer; white-space:nowrap;
}
table.services thead th:hover{ color:var(--ink); }
table.services tbody td{
  padding:10px 12px; border-bottom:1px solid var(--line-soft); vertical-align:middle;
}
table.services tbody tr:hover{ background:var(--bg-panel-2); }
.proto{ font-family:var(--f-display); color:var(--ink-dim); font-size:12.5px; }
.svc-type{ display:inline-flex; align-items:center; gap:6px; }
.svc-type .icon{ font-size:14px; }

/* runway bar — signature element: tempo atual vs. limite do prazo */
.runway{ width:110px; }
.runway .track{
  position:relative; height:6px; border-radius:4px; background:var(--bg-raised);
  overflow:hidden; margin-bottom:4px;
}
.runway .fill{ position:absolute; inset:0 auto 0 0; height:100%; border-radius:4px; }
.runway .fill.ok{ background:var(--ok); }
.runway .fill.warn{ background:var(--warn); }
.runway .fill.crit{ background:var(--crit); }
.runway .meta{ font-family:var(--f-display); font-size:11px; color:var(--ink-faint); }

.badge{
  display:inline-flex; align-items:center; gap:5px;
  padding:3px 9px; border-radius:99px; font-size:11.5px; font-weight:700;
  letter-spacing:.02em;
}
.badge.ok{ background:var(--ok-wash); color:var(--ok); }
.badge.crit{ background:var(--crit-wash); color:var(--crit); }
.badge .dot{ width:6px; height:6px; border-radius:50%; background:currentColor; }

.row-actions{ display:flex; gap:6px; }
.icon-btn{
  background:transparent; border:1px solid var(--line); color:var(--ink-faint);
  border-radius:5px; width:26px; height:26px; cursor:pointer; font-size:12px;
}
.icon-btn:hover{ color:var(--ink); border-color:var(--ink-faint); }

.empty-state{
  padding:48px 24px; text-align:center; color:var(--ink-dim);
}
.empty-state .glyph{ font-size:32px; margin-bottom:10px; }
.empty-state h3{ margin:0 0 6px; color:var(--ink); }
.empty-state p{ margin:0 0 16px; font-size:13.5px; }

/* ---------------- map panel ---------------- */
.map-panel{ height:640px; display:flex; flex-direction:column; overflow:hidden; }
.map-panel .map-head{
  display:flex; align-items:center; justify-content:space-between;
  padding:12px 14px; border-bottom:1px solid var(--line);
}
.map-panel .map-head .title{ font-weight:700; font-size:13.5px; }
.map-panel .map-head .legend{ display:flex; gap:12px; font-size:11.5px; color:var(--ink-dim); }
.map-panel .map-head .legend span{ display:inline-flex; align-items:center; gap:5px; }
.map-panel .map-head .legend .sw{ width:8px; height:8px; border-radius:50%; }
#map{ flex:1; min-height:0; background:#0c1013; }

.leaflet-popup-content-wrapper{ background:var(--bg-panel-2); color:var(--ink); border-radius:8px; }
.leaflet-popup-tip{ background:var(--bg-panel-2); }
.popup-svc .proto{ display:block; margin-bottom:4px; }
.popup-svc .title{ font-weight:700; font-size:13px; margin-bottom:3px; }
.popup-svc .meta{ font-size:12px; color:var(--ink-dim); }
.popup-svc .approx{ color:var(--warn); font-size:11px; margin-top:5px; }

.marker-emoji{
  display:flex; align-items:center; justify-content:center;
  width:26px; height:26px; border-radius:50% 50% 50% 4px;
  transform:rotate(45deg); box-shadow:0 2px 6px rgba(0,0,0,.4);
  border:2px solid rgba(0,0,0,.25);
}
.marker-emoji span{ transform:rotate(-45deg); font-size:13px; }
.marker-emoji.ok{ background:var(--ok); }
.marker-emoji.crit{ background:var(--crit); }

/* ---------------- modal ---------------- */
.modal-backdrop{
  position:fixed; inset:0; background:rgba(6,8,10,.6); backdrop-filter:blur(2px);
  display:flex; align-items:flex-start; justify-content:center; padding:40px 16px;
  z-index:200; overflow:auto;
}
.modal{
  width:100%; max-width:560px; background:var(--bg-panel); border:1px solid var(--line);
  border-radius:var(--radius); box-shadow:var(--shadow); padding:22px;
}
.modal h3{ margin:0 0 4px; }
.modal .modal-sub{ color:var(--ink-dim); font-size:13px; margin:0 0 18px; }
.modal .grid2{ display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.modal .field{ margin-bottom:12px; }
.modal .field label{ margin-bottom:6px; }
